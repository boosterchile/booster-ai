#!/usr/bin/env bash
# Booster AI — pre-commit: escaneo de secretos + lint-staged
set -e

echo "[pre-commit] Escaneando secretos con gitleaks..."
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --verbose --redact --no-banner || {
    echo ""
    echo "[ERROR] gitleaks detecto posibles secretos en archivos staged."
    echo "        Revisa. Si es falso positivo, usa 'git commit --no-verify' con justificacion."
    exit 1
  }
else
  echo "[pre-commit] WARN: gitleaks no instalado. Instalar: brew install gitleaks"
fi

echo "[pre-commit] Ejecutando lint-staged (Biome)..."
npx lint-staged

echo "[pre-commit] Verificando numeracion ADR (check-adr-numbering)..."
node scripts/repo-checks/check-adr-numbering.mjs --allow-legacy 028,034,035 || {
  echo ""
  echo "[ERROR] Colision de numeros ADR detectada en docs/adr/."
  echo "        Renombra el ADR nuevo al siguiente numero libre."
  exit 1
}

# T1.1 of S1a: bloquea commits que tocan packages/shared-schemas/src/domain/
# si el drift inventory tiene gate: PENDING_PO (cubre SC-S1.0 enforcement).
INVENTORY_FILE=".specs/s1-drift-coverage-e2e/inventory.md"
DOMAIN_DIR_PATTERN="packages/shared-schemas/src/domain/"
if [ -f "$INVENTORY_FILE" ]; then
  DOMAIN_STAGED=$(git diff --cached --name-only | grep "^${DOMAIN_DIR_PATTERN}" || true)
  if [ -n "$DOMAIN_STAGED" ]; then
    GATE=$(head -3 "$INVENTORY_FILE" | grep '^gate:' | awk '{print $2}')
    if [ "$GATE" = "PENDING_PO" ]; then
      echo ""
      echo "[ERROR] Commits que tocan ${DOMAIN_DIR_PATTERN} bloqueados por gate SC-S1.0."
      echo "        $INVENTORY_FILE tiene 'gate: PENDING_PO'."
      echo "        Acción: revisar $INVENTORY_FILE + .specs/s1-drift-coverage-e2e/inventory-classification.md"
      echo "        Tras clasificar A/B/C, cambiar 'gate: PENDING_PO' por 'gate: APPROVED_BY_PO <fecha>'."
      exit 1
    fi
  fi
fi

echo "[pre-commit] OK"
