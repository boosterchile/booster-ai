{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm ci:*)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm security:scan:*)",
      "Bash(pnpm security:scan-staged:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git remote -v)",
      "Bash(git config --get:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat docs/*)",
      "Bash(cat README.md)",
      "Bash(cat AUDIT.md)",
      "Bash(cat HANDOFF.md)",
      "Bash(cat CLAUDE.md)",
      "Bash(cat AGENTS.md)",
      "Bash(node --version)",
      "Bash(pnpm --version)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(curl -s localhost:*)",
      "Bash(curl -s 127.0.0.1:*)",
      "Bash(curl -fsS http://localhost:*)",
      "mcp__playwright__*"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(gcloud:*)",
      "Bash(kubectl:*)",
      "Bash(terraform:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(rm:*)",
      "Bash(pnpm publish:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --no-verify:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git reset --hard origin/main)",
      "Bash(git reset --hard main)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf .git:*)",
      "Bash(rm -rf node_modules:*)"
    ]
  },
  "enabledMcpjsonServers": ["playwright"]
}
