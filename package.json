{
  "name": "@booster-ai/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Booster AI — Marketplace B2B de logística sostenible con IA, arquitectura cloud-native sobre GCP.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test:coverage",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "security:scan": "gitleaks detect --source . --verbose --redact --no-banner",
    "security:scan-staged": "gitleaks protect --staged --verbose --redact --no-banner",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.11",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "turbo": "^2.3.3",
    "typescript": "^5.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": ["biome check --write --no-errors-on-unmatched"]
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"],
    "overrides": {
      "crypto-js@<4.2.0": ">=4.2.0",
      "serialize-javascript@<7.0.3": ">=7.0.3"
    }
  }
}
