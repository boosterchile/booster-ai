# ==============================================================================
# Booster AI — .gitignore raíz
# Zero-trust por defecto: solo lo necesario se trackea.
# ==============================================================================

# -------- Credenciales y secretos (CRÍTICO) --------
# Service accounts GCP / Firebase
*service-account*.json
*service_account*.json
*-key.json
*_key.json
firebase-adminsdk-*.json
gcp-key-*.json
application_default_credentials.json

# Llaves privadas y certificados
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
id_rsa
id_ed25519
id_ecdsa

# Archivos de entorno (solo .env.example se trackea)
.env
.env.*
!.env.example
!.env.*.example

# Credential helpers / token caches
.netrc
.npmrc
!.npmrc.example
.pypirc
.aws/credentials
.gcloud/
.config/gcloud/

# -------- Dependencias --------
node_modules/
.pnp
.pnp.js
.pnpm-store/

# -------- Builds y outputs --------
dist/
build/
out/
.next/
.turbo/
.vite/
coverage/
.nyc_output/
*.tsbuildinfo

# -------- Tests --------
test-results/
playwright-report/
playwright/.cache/
.playwright-mcp/
blob-report/

# -------- Logs --------
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# -------- OS / Editor --------
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# -------- Terraform --------
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.local
*.tfvars.json
!*.tfvars.example
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log
# Plan binarios — efímeros, no committear (regenerar con terraform plan)
tfplan
*.tfplan

# -------- Docker --------
docker-compose.override.yml
docker-compose.override.yaml

# -------- Temp / scratch --------
tmp/
temp/
*.tmp
*.bak
*.orig

# -------- Database dumps --------
*.sql.gz
*.dump

# -------- Python venv (si algún script lo usa puntualmente) --------
.venv/
venv/
__pycache__/
*.pyc

# macOS/Finder/iCloud duplicados accidentales
* 2.*
* 3.*

# Claude Code local settings
.claude/
