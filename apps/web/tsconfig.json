{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable", "WebWorker"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "types": ["vite/client", "vite-plugin-pwa/client"]
  },
  "include": ["src/**/*", "test/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
