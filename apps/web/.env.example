# Booster AI Web — variables de entorno (frontend)
# Las variables prefijadas con VITE_ quedan disponibles en el bundle.
# NO poner secrets del backend aquí.

VITE_API_URL=http://localhost:8080
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=booster-ai-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=booster-ai-dev
VITE_FIREBASE_STORAGE_BUCKET=booster-ai-dev.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=XXXXXXXXX
VITE_FIREBASE_APP_ID=1:XXX:web:XXX
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-frontend-key
