# apps/marketing — variables de entorno (todas NEXT_PUBLIC_*; Next las inlina
# en el bundle cliente en build time). Copiar a `.env.local` para desarrollo.

# Base del api Booster, usada por /signup para POST /api/v1/signup-request.
# Opcional para el contenido/SEO; requerida para el /signup funcional.
NEXT_PUBLIC_API_URL=https://api.boosterchile.com

# Kill-switch del /signup funcional (ADR-060). Fail-closed: SOLO el literal
# "true" habilita el formulario; cualquier otro valor —o ausente— deja
# /signup en "próximamente". Flip a "true" solo con el readiness de
# .specs/marketing-site-signup-request/spec.md §11 (CORS + downstream).
NEXT_PUBLIC_SIGNUP_ENABLED=false
