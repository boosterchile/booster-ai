# Booster AI API — variables de entorno
# Ver packages/config/src/schemas/ para schemas Zod que validan cada valor.

# === Común ===
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug
SERVICE_NAME=booster-ai-api
SERVICE_VERSION=0.0.0-dev

# === GCP ===
GOOGLE_CLOUD_PROJECT=booster-ai-dev
# GOOGLE_APPLICATION_CREDENTIALS solo en dev local — en Cloud Run usa metadata server
GOOGLE_APPLICATION_CREDENTIALS=/Users/you/.config/booster/service-account.json

# === Database ===
DATABASE_URL=postgresql://booster:devpass@localhost:5432/booster_ai?schema=public
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=5000

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_TLS=false

# === Firebase ===
FIREBASE_PROJECT_ID=booster-ai-dev

# === API específicas ===
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_ISSUER=booster-ai
