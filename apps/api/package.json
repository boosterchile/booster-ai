{
  "name": "@booster-ai/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:integration:lint": "node ./scripts/check-no-concurrent-in-integration.mjs",
    "pretest:integration": "pnpm run test:integration:lint",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "test:all": "pnpm run test && pnpm run test:integration",
    "load-test:smoke": "k6 run test/load/smoke.k6.js"
  },
  "dependencies": {
    "@booster-ai/carbon-calculator": "workspace:*",
    "@booster-ai/routes-api-client": "workspace:*",
    "@booster-ai/certificate-generator": "workspace:*",
    "@booster-ai/coaching-generator": "workspace:*",
    "@booster-ai/config": "workspace:*",
    "@booster-ai/driver-scoring": "workspace:*",
    "@booster-ai/factoring-engine": "workspace:*",
    "@booster-ai/logger": "workspace:*",
    "@booster-ai/matching-algorithm": "workspace:*",
    "@booster-ai/notification-fan-out": "workspace:*",
    "@booster-ai/otel-bootstrap": "workspace:*",
    "@booster-ai/pricing-engine": "workspace:*",
    "@booster-ai/shared-schemas": "workspace:*",
    "@booster-ai/transport-documents": "workspace:*",
    "@booster-ai/trip-state-machine": "workspace:*",
    "@booster-ai/whatsapp-client": "workspace:*",
    "@google-cloud/kms": "^4.5.0",
    "@google-cloud/opentelemetry-cloud-trace-exporter": "^3.0.0",
    "@google-cloud/pubsub": "^4.10.0",
    "@google-cloud/storage": "^7.13.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.7.6",
    "@hyzyla/pdfium": "2.1.13",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.36.0",
    "@signpdf/placeholder-plain": "^3.2.4",
    "@signpdf/signpdf": "^3.2.4",
    "@signpdf/utils": "^3.2.4",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "5.9.2",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "hono": "^4.12.25",
    "import-in-the-middle": "^1.13.0",
    "ioredis": "^5.4.2",
    "node-forge": "^1.3.1",
    "pdf-lib": "^1.17.1",
